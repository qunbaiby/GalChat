[sub_resource type="Shader" id="Shader_AvatarCircle"]
code = "shader_type canvas_item;

void fragment() {
	vec2 centered_uv = UV * 2.0 - vec2(1.0);
	float mask = smoothstep(1.0, 0.94, length(centered_uv));
	vec4 tex = texture(TEXTURE, UV);
	COLOR = vec4(tex.rgb, tex.a * mask);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_AvatarCircle"]
