[node name="Desc" type="Label" parent="MBTIPopup/Margin/VBox/HeaderCard/HeaderMargin/HeaderVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.36, 0.42, 0.45, 1)
theme_override_font_sizes/font_size = 13
text = "选择一个最贴近你的性格标签，Luna 会把它作为理解你的起点。"
horizontal_alignment = 1
autowrap_mode = 3

[node name="HintCard" type="PanelContainer" parent="MBTIPopup/Margin/VBox"]
layout_mode = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_InfoCard")

[node name="HintMargin" type="MarginContainer" parent="MBTIPopup/Margin/VBox/HintCard"]
layout_mode = 2
theme_override_constants/margin_left = 14
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 14
theme_override_constants/margin_bottom = 10

[node name="HintLabel" type="Label" parent="MBTIPopup/Margin/VBox/HintCard/HintMargin"]
layout_mode = 2
theme_override_colors/font_color = Color(0.34, 0.4, 0.43, 1)
theme_override_font_sizes/font_size = 12
text = "已选择的类型会高亮显示，你可以随时重新选择。"
horizontal_alignment = 1
autowrap_mode = 3

[node name="Scroll" type="ScrollContainer" parent="MBTIPopup/Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="MBTIGrid" type="GridContainer" parent="MBTIPopup/Margin/VBox/Scroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 15
theme_override_constants/v_separation = 15
columns = 2

[node name="CloseMBTI" type="Button" parent="MBTIPopup/Margin/VBox"]
unique_name_in_owner = true
custom_minimum_size = Vector2(150, 45)
layout_mode = 2
size_flags_horizontal = 4
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_styles/normal = SubResource("StyleBoxFlat_ButtonPrimary")
theme_override_styles/pressed = SubResource("StyleBoxFlat_ButtonPrimary")
theme_override_styles/hover = SubResource("StyleBoxFlat_ButtonPrimary")
text = "返回"
