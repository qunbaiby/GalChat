[sub_resource type="Shader" id="Shader_ConfirmBlur"]
code = "shader_type canvas_item;
uniform sampler2D screen_texture : hint_screen_texture, filter_linear_mipmap;
uniform float lod: hint_range(0.0, 5.0) = 2.7;
uniform vec4 mix_color: source_color = vec4(0.05, 0.10, 0.12, 0.34);

void fragment() {
	vec4 bg = textureLod(screen_texture, SCREEN_UV, lod);
	COLOR = vec4(mix(bg.rgb, mix_color.rgb, mix_color.a), COLOR.a);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_ConfirmBlur"]
shader = SubResource("Shader_ConfirmBlur")
shader_parameter/lod = 2.7
shader_parameter/mix_color = Color(0.05, 0.1, 0.12, 0.34)

[sub_resource type="Shader" id="Shader_PopupPanelGradient"]
code = "shader_type canvas_item;
uniform vec4 color_top : source_color = vec4(0.43, 0.84, 0.78, 1.0);
uniform vec4 color_mid : source_color = vec4(0.77, 0.94, 0.91, 1.0);
uniform vec4 color_bottom : source_color = vec4(0.99, 0.995, 0.99, 1.0);
uniform float mid_point : hint_range(0.0, 1.0) = 0.42;

void fragment() {
	float t = clamp(UV.y, 0.0, 1.0);
	vec4 gradient = color_bottom;
	if (t < mid_point) {
		float top_mix = 0.0;
		if (mid_point > 0.0) {
			top_mix = t / mid_point;
		}
		gradient = mix(color_top, color_mid, top_mix);
	} else {
		float bottom_mix = 1.0;
		if (mid_point < 1.0) {
			bottom_mix = (t - mid_point) / (1.0 - mid_point);
		}
		gradient = mix(color_mid, color_bottom, bottom_mix);
	}
	COLOR = vec4(gradient.rgb, gradient.a * COLOR.a);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_ukko6"]
shader = SubResource("Shader_PopupPanelGradient")
shader_parameter/color_top = Color(0.36078432, 0.7764706, 0.7529412, 1)
