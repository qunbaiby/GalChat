[sub_resource type="Shader" id="Shader_RoundedTexture"]
code = "shader_type canvas_item;
uniform float radius = 22.0;

void fragment() {
	vec2 size = 1.0 / TEXTURE_PIXEL_SIZE;
	vec2 p = UV * size;
	vec2 edge = min(p, size - p);
	float mask = step(radius, min(edge.x, edge.y));
	vec4 tex = texture(TEXTURE, UV) * COLOR;
	COLOR = vec4(tex.rgb, tex.a * mask);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_PreviewRounded"]
