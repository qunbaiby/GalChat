[sub_resource type="Shader" id="Shader_ExecutionBlur"]
code = "shader_type canvas_item;
uniform sampler2D screen_texture : hint_screen_texture, filter_linear_mipmap;
uniform float lod: hint_range(0.0, 5) = 2.0;
uniform vec4 mix_color: source_color = vec4(0.0, 0.0, 0.0, 0.4);

void fragment() {
	vec4 bg = textureLod(screen_texture, SCREEN_UV, lod);
	COLOR = vec4(mix(bg.rgb, mix_color.rgb, mix_color.a), COLOR.a);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_ExecutionBlur"]
shader = SubResource("Shader_ExecutionBlur")
shader_parameter/lod = 3.2
shader_parameter/mix_color = Color(0.18, 0.19, 0.22, 0.28)

