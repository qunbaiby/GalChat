[gd_scene load_steps=2 format=3]

[sub_resource type="StyleBoxFlat" id="PanelStyle"]
bg_color = Color(0.99, 0.985, 0.98, 1)
border_width_left = 3
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(0.78, 0.52, 0.48, 0.55)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

[node name="FailedTaskItem" type="PanelContainer"]
theme_override_styles/panel = SubResource("PanelStyle")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 14
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 14
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 7

[node name="Header" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="TypeLabel" type="Label" parent="Margin/VBox/Header"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_colors/font_color = Color(0.2, 0.3, 0.31, 1)
theme_override_font_sizes/font_size = 14
text = "记忆提取"

[node name="TimeLabel" type="Label" parent="Margin/VBox/Header"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.46, 0.5, 0.51, 1)
theme_override_font_sizes/font_size = 12
text = "未记录"

[node name="ErrorLabel" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.67, 0.25, 0.29, 1)
theme_override_font_sizes/font_size = 13
text = "错误详情"
autowrap_mode = 3

[node name="Footer" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="AttemptsLabel" type="Label" parent="Margin/VBox/Footer"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_colors/font_color = Color(0.46, 0.5, 0.51, 1)
theme_override_font_sizes/font_size = 12
text = "已尝试 5 次"

[node name="RetryButton" type="Button" parent="Margin/VBox/Footer"]
unique_name_in_owner = true
custom_minimum_size = Vector2(72, 30)
layout_mode = 2
theme_override_font_sizes/font_size = 12
text = "重试"

[node name="DiscardButton" type="Button" parent="Margin/VBox/Footer"]
unique_name_in_owner = true
custom_minimum_size = Vector2(72, 30)
layout_mode = 2
theme_override_colors/font_color = Color(0.67, 0.25, 0.29, 1)
theme_override_font_sizes/font_size = 12
text = "丢弃"