[ext_resource type="Script" uid="uid://qg2cmholu3ki" path="res://scripts/ui/main/drawing_board_panel.gd" id="1_script"]

[sub_resource type="Shader" id="Shader_Blur"]
code = "shader_type canvas_item;
uniform sampler2D screen_texture : hint_screen_texture, filter_linear_mipmap;
uniform float lod: hint_range(0.0, 5.0) = 2.6;
uniform vec4 mix_color: source_color = vec4(0.05, 0.10, 0.12, 0.34);

void fragment() {
	vec4 bg = textureLod(screen_texture, SCREEN_UV, lod);
	COLOR = vec4(mix(bg.rgb, mix_color.rgb, mix_color.a), COLOR.a);
}
"

