[sub_resource type="Shader" id="Shader_BgSettingBlur"]
code = "shader_type canvas_item;
uniform float lod: hint_range(0.0, 5) = 2.0;
uniform vec4 mix_color: source_color = vec4(0.95, 0.97, 1.0, 0.22);

void fragment() {
	vec4 bg = textureLod(TEXTURE, UV, lod);
	COLOR = vec4(mix(bg.rgb, mix_color.rgb, mix_color.a), bg.a * COLOR.a);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_BgSettingBlur"]
shader = SubResource("Shader_BgSettingBlur")
shader_parameter/lod = 2.5
shader_parameter/mix_color = Color(0.95, 0.97, 1, 0.24)

[sub_resource type="Shader" id="Shader_PanelRootGradient"]
code = "shader_type canvas_item;
uniform vec4 top_color: source_color = vec4(1.0, 1.0, 1.0, 0.78);
uniform vec4 bottom_color: source_color = vec4(0.94, 0.96, 0.99, 0.58);

void fragment() {
	vec4 grad = mix(top_color, bottom_color, UV.y);
	COLOR = vec4(grad.rgb, grad.a * COLOR.a);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_PanelRootGradient"]
shader = SubResource("Shader_PanelRootGradient")
