{
    "script_id": "intro_story",
    "chapters": {
        "start": {
            "events": [
                {
                    "type": "background",
                    "bg_id": "main_bg_1",
                    "transition_type": "fade",
                    "duration": 0.1
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "一个月前，工作室的宁静被一阵电话铃声打破，来电的是许久未见的好友妮可。"
                },
                {
                    "type": "voice_call",
                    "call_id": "intro_call_nicole"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "一如既往地没给我任何反驳的机会，妮可便轻巧地挂断了电话。"
                },
                {
                    "type": "audio",
                    "audio_id": "doorbell",
                    "audio_type": "se",
                    "action": "play"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "几乎就在下一秒，工作室的门铃轻轻响起，声音清脆，又带着一丝小心翼翼。"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "我起身开门，午后的暖光正好洒落在门口的少女身上——"
                },                      
                {
                    "type": "background",
                    "bg_id": "story_cg_0",
                    "transition_type": "blur",
                    "duration": 1.5
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "她安静地站着，手指不自觉地攥着衣角，眉间藏着掩不住的迷茫与落寞。她的目光怯生生的，却又隐约透出一点期待。"
                },   
                {
                    "type": "show_character",
                    "animation": "fade_in"
                },
                {
                    "type": "dialogue",
                    "speaker": "luna",
                    "content": "您好，我是Luna，是妮可老师让我来的……请问您就是……呃……\n（她挠了挠头，像是努力回想什么。我猜她大概是忘了我的名字）"
                },
                {
                    "type": "show_player_info_popup"
                },
                {
                    "type": "dialogue",
                    "speaker": "luna",
                    "content": "【玩家名称】老师好！妮可老师说你在那方面非常厉害，拜托您帮帮我～"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "只是这样一句简单的问候，我似乎就明白了妮可提起她时为何会欲言又止。"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "而我与这位少女的故事，也由此悄然开始……"
                },
                {
                    "type": "start_free_chat",
                    "strategy": "玩家刚刚收下了妮可带来的委托，同意指导Luna。请以Luna的身份，带着感激又有点怯生生的语气，向玩家做个简单的自我介绍，并表达自己对未来的迷茫。",
                    "max_rounds": 5
                }
            ]
        }
    }
}