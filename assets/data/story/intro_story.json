{
    "script_id": "intro_story",
    "chapters": {
        "start": {
            "events": [
                {
                    "type": "background",
                    "bg_id": "main_bg_0",
                    "transition_type": "fade",
                    "duration": 0.1
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "一个月前，工作室的宁静被一阵电话铃声打破，来电的是断联许久的好友妮可。"
                },
                {
                    "type": "voice_call",
                    "call_id": "intro_call_nicole"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "妮可一如既往地没给我反驳的余地就挂了电话。"
                },
                {
                    "type": "audio",
                    "audio_id": "doorbell",
                    "audio_type": "se",
                    "action": "play"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "几乎同时，工作室的门铃轻轻响起，清脆又带着几分小心翼翼，生怕惊扰了屋里的宁静。"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "我起身开门，午后的暖光洒在门口少女身上，那一刻我忽然恍惚——"
                },
                {
                    "type": "background",
                    "bg_id": "story_cg_0",
                    "transition_type": "fade",
                    "duration": 1.5
                },
                {
                    "type": "background",
                    "bg_id": "story_cg_1",
                    "transition_type": "blur",
                    "duration": 1.5
                },
                {
                    "type": "background",
                    "bg_id": "story_cg_0",
                    "transition_type": "blur",
                    "duration": 1.0
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "我下意识开口，声音带着不易察觉的怔忡。"
                },
                {
                    "type": "dialogue",
                    "speaker": "我",
                    "content": "……ava？"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "少女身体微僵，怯生生的目光里多了几分茫然，懵懂地望着我。"
                },
                {
                    "type": "show_character",
                    "animation": "fade_in"
                },
                {
                    "type": "dialogue",
                    "speaker": "luna",
                    "content": "您好，我是Luna，是妮可老师推荐我来的……请问您就是……呃……"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "她挠了挠头，眉头微蹙，像是在回想我的名字，又像是被我刚才的呼唤打乱了思绪，一时语塞。"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "我猜她大抵忘了我的名字，也疑惑我为何忽然叫出一个不属于她的名字。"
                },
                {
                    "type": "show_player_info_popup"
                },
                {
                    "type": "dialogue",
                    "speaker": "player",
                    "content": "你好Luna，我叫{player_name}。"
                },
                {
                    "type": "dialogue",
                    "speaker": "luna",
                    "content": "{player_name}{player_title}好！妮可老师说您再那方面很厉害，拜托您帮帮我～"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "与记忆中的女孩截然不同而又别开生面的问候，吹散了我的恍惚。"
                },
                {
                    "type": "dialogue",
                    "speaker": "旁白",
                    "content": "她并不是她，而我与她的故事也自此开始……"
                },
                {
                    "type": "jump",
                    "target_chapter": "end"
                }
            ]
        }
    }
}