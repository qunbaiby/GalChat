                    "text": "这里会显示你刚才选中分类下的课程列表。现在可以继续切换上方 tab，然后从这里点击一门课程，把它安排到下方 MorningRow 的槽位里。",
                    "wait_action": "activity_add_course",
                    "target_scene": "activity",
                    "requires_scene": "activity",
                    "target_mode": "activity_list",
                    "focus_targets": [
                        {
                            "target_mode": "category_tabs",
                            "highlight_padding": 0
