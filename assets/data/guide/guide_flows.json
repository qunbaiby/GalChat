{
    "guides": [
        {
            "id": "schedule_onboarding_guide",
            "title": "行程安排新手引导",
            "guide_category": "schedule_onboarding",
            "auto_start_after_intro": true,
            "steps": [
                {
                    "id": "open_schedule_panel",
                    "type": "wait_action",
                    "step_category": "schedule",
                    "title": "打开行程安排",
                    "text": "欢迎来到主场景。先点击主行动按钮里的“行程安排”，我会带你完成第一次课程安排教学。",
                    "wait_action": "open_schedule",
                    "target_scene": "main",
                    "requires_scene": "main",
                    "highlight_feature": "main.main_action",
                    "feature_updates": {
                        "main.main_action": true,
                        "main.affection": false
                    },
                    "scene_hint": "如果当前主按钮不是“行程安排”，请先确认当前是否处于适合安排课程的时段。"
                },
                {
                    "id": "explain_schedule_tabs",
                    "type": "wait_action",
                    "step_category": "schedule",
                    "title": "课程类型切换",
                    "text": "这里是课程类型切换区。先点击一次课程类型 tab，看看不同课程分类如何切换。切换后我会继续介绍下方对应的课程列表。",
                    "wait_action": "activity_switch_category",
                    "target_scene": "activity",
                    "requires_scene": "activity",
                    "target_mode": "category_tabs",
                    "hide_until_scene_ready": true,
                    "highlight_padding": 0
