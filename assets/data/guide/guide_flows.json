                    "requires_scene": "wechat",
                    "target_mode": "fixed_options",
                    "hide_until_scene_ready": true
                },
                {
                    "id": "explain_wechat_fixed_conversation",
                    "type": "wait_action",
                    "step_category": "wechat",
                    "title": "把整段对话发完",
                    "text": "选项内容已经放进输入框了。先点击发送，把第一句回复发出去；从这之后到整段固定对话结束前，高亮都会一直保持在整个聊天区域，不再变化。你只要继续按流程点完后续选项并发完全部内容；等系统提示本次对话已结束后，再点击一次高亮区域，我就带你进入关闭微聊的下一步。",
                    "wait_action": "wechat_acknowledge_fixed_conversation_finished",
