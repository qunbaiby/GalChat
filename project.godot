; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GalChat"
run/main_scene="res://scenes/ui/start/start_scene.tscn"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

driver/enable_input=true
input/transcribe/max_tokens=500

[autoload]

GameDataManager="*res://scripts/data/game_data_manager.gd"
PromptManager="*res://scripts/data/prompt_manager.gd"
DoubaoEmbeddingClient="*res://scripts/api/doubao_embedding_client.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=1
window/size/always_on_top=true
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="GalChat"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_whisper/plugin.cfg")

[file_customization]

folder_colors={
"res://scripts/": "red"
}

[gui]

theme/custom="res://assets/themes/galchat_theme.tres"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
