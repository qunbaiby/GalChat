[configuration]

entry_symbol = "gd_cubism_library_init"
compatibility_minimum = 4.3

[libraries]

windows.editor.x86_64 = "bin/libgd_cubism.windows.debug.x86_64.dll"
windows.debug.x86_64 = "bin/libgd_cubism.windows.debug.x86_64.dll"
windows.release.x86_64 = "bin/libgd_cubism.windows.release.x86_64.dll"

[dependencies]

windows.debug.x86_64 = {
	"bin/Live2DCubismCore.dll": ""
}
windows.release.x86_64 = {
	"bin/Live2DCubismCore.dll": ""
}
